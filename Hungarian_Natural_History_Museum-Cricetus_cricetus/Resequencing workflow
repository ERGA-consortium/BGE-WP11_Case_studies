>done | parallel -j 20

#we will now remove secondary alignments by using samtools flag combination '-F 256' ("not primary alignment")
for i in $bams
>do echo "samtools view -@ 1 -bh -F 256 ./coord_bam/${i}_f_c_s_f_coord.bam . > ./prim_bam/${i}_f_c_s_f_c_prim.bam"
